# ── PostgreSQL ───────────────────────────────
POSTGRES_USER=codown
POSTGRES_PASSWORD=changeme
POSTGRES_DB=codown
POSTGRES_PORT=5432

# ── Server ───────────────────────────────────
SERVER_PORT=5000
JWT_ACCESS_SECRET=change_this_jwt_access_secret
JWT_REFRESH_SECRET=change_this_jwt_refresh_secret
CLIENT_URL=http://localhost

# ── Client (Vite build args) ─────────────────
# These are baked into the JS bundle at build time
VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000

# ── Client port ──────────────────────────────
CLIENT_PORT=81
